rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helpers ──────────────────────────────────────────────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdfOrImage() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    function maxSize(mb) {
      return request.resource.size <= mb * 1024 * 1024;
    }

    // ─── Member profile photo ──────────────────────────────────────────────
    // members/{userId}/profile_photo
    // Owner read/write only, max 5 MB, images only
    match /members/{userId}/profile_photo {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isImage() && maxSize(5);
    }

    // ─── Member documents ──────────────────────────────────────────────────
    // members/{userId}/docs/{fileName}
    // Owner write, admin read, max 10 MB, images or PDF
    match /members/{userId}/docs/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isPdfOrImage() && maxSize(10);
    }

    // ─── Payment receipts ──────────────────────────────────────────────────
    // receipts/{userId}/{fileName}
    // Owner write (overwrite allowed for corrections), admin read, max 10 MB, images only
    match /receipts/{userId}/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isImage() && maxSize(10);
    }

    // ─── Deny everything else ─────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
